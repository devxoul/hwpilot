{
  "name": "hwpilot",
  "version": "0.1.0",
  "description": "HWP Copilot",
  "repository": {
    "type": "git",
    "url": "https://github.com/devxoul/hwpilot"
  },
  "bin": {
    "hwpilot": "./src/cli.ts"
  },
  "files": [
    "dist/",
    "skills/",
    ".claude-plugin/"
  ],
  "type": "module",
  "main": "dist/src/cli.js",
  "module": "dist/src/cli.js",
  "scripts": {
    "build": "tsc && tsc-alias --resolve-full-paths",
    "postbuild": "bun scripts/postbuild.ts",
    "test": "bun test src/",
    "test:e2e": "bun test e2e/",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --write .",
    "prepublishOnly": "bun run build && bun run typecheck && bun test src/ && bun scripts/prepublish.ts",
    "postpublish": "git checkout package.json"
  },
  "dependencies": {
    "cfb": "^1.2.2",
    "commander": "^11.1.0",
    "fast-xml-parser": "^4.3.2",
    "jszip": "^3.10.1",
    "pako": "^2.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^20.10.6",
    "@types/pako": "^2.0.4",
    "oxfmt": "latest",
    "oxlint": "latest",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3"
  }
}
